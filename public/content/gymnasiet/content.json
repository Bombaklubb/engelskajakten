      "title": "Advanced Tenses",
      "description": "Past perfect, future perfect och progressiva former.",
      "icon": "⏰",
      "pointsRequired": 0,
      "bonusPoints": 30,
      "exercises": [
        {
          "id": "gym-g1-1",
          "type": "multiple-choice",
          "question": "Which sentence uses the past perfect correctly?",
          "options": [
            "When she arrived, he already left.",
            "When she arrived, he had already left.",
            "When she arrived, he has already left.",
            "When she arrived, he was already leaving."
          ],
          "correctIndex": 1,
          "explanation": "Past perfect (had + past participle) is used for an action completed BEFORE another past action. 'He had left' happened before 'she arrived'."
        },
        {
          "id": "gym-g1-2",
          "type": "fill-in-blank",
          "sentence": "By the time you read this letter, I ___ (leave) the country.",
          "answer": "will have left",
          "hint": "Future perfect: will + have + past participle",
          "explanation": "Future perfect (will + have + past participle) describes an action completed before a specific point in the future."
        }
      ]
    },
