{
  "grammar": [
    {
      "id": "hog-g1-perfect",
      "title": "Present Perfect",
      "description": "Perfektum — om erfarenheter och nyligen avslutade händelser.",
      "icon": "✅",
      "pointsRequired": 0,
      "bonusPoints": 25,
      "exercises": [
        {
          "id": "hog-g1-1",
          "type": "multiple-choice",
          "question": "Which sentence is in the present perfect?",
          "options": [
            "She visited Paris last year.",
            "She has visited Paris.",
            "She is visiting Paris.",
            "She visits Paris often."
          ],
          "correctIndex": 1,
          "explanation": "Present perfect = have/has + past participle. 'She has visited' = she has the experience of visiting Paris."
        },
        {
          "id": "hog-g1-2",
          "type": "fill-in-blank",
          "sentence": "I ___ (never/eat) sushi before.",
          "answer": "have never eaten",
          "hint": "Present perfect with 'never': have/has + never + past participle",
          "explanation": "For experiences: I have never eaten sushi — it means this is an experience you haven't had yet."
        }
      ]
    },
    {
      "id": "hog-g2-conditionals",
      "title": "Conditional Sentences",
      "description": "If-satser — typ 1 och 2 konditionalis.",
      "icon": "🔀",
      "pointsRequired": 0,
      "bonusPoints": 25,
      "exercises": [
        {
          "id": "hog-g2-1",
          "type": "multiple-choice",
          "question": "Which is a correct First Conditional sentence?",
          "options": [
            "If it will rain, I would stay inside.",
            "If it rains, I will stay inside.",
            "If it rained, I will stay inside.",
            "If it rains, I would stay inside."
          ],
          "correctIndex": 1,
          "explanation": "First Conditional (real/possible situations): If + present simple, will + base verb."
        },
        {
          "id": "hog-g2-2",
          "type": "fill-in-blank",
          "sentence": "If I ___ (be) taller, I would play basketball.",
          "answer": "were",
          "hint": "Second Conditional uses past tense in the if-clause. 'Be' becomes 'were' for all subjects.",
          "explanation": "Second Conditional (hypothetical/unreal): If + past simple (were for all), would + base verb."
        }
      ]
    },
    {
      "id": "hog-g3-passive",
      "title": "The Passive Voice",
      "description": "Passivum — när objektet blir subjekt.",
      "icon": "🔄",
      "pointsRequired": 0,
      "bonusPoints": 25,
      "exercises": [
        {
          "id": "hog-g3-1",
          "type": "multiple-choice",
          "question": "Which sentence is in the passive voice?",
          "options": [
            "The chef cooked the meal.",
            "The meal was cooked by the chef.",
            "The chef is cooking the meal.",
            "The chef will cook the meal."
          ],
          "correctIndex": 1,
          "explanation": "Passive voice: be + past participle. 'The meal was cooked' — the meal receives the action."
        },
        {
          "id": "hog-g3-2",
          "type": "fill-in-blank",
          "sentence": "The Eiffel Tower ___ (build) in 1889.",
          "answer": "was built",
          "hint": "Passive past simple: was/were + past participle",
          "explanation": "Past passive: was/were + past participle. Build → built. 'was built' = someone built it (in the past)."
        }
      ]
    },
    {
      "id": "hog-g4-reported",
      "title": "Reported Speech",
      "description": "Indirekt tal — återberätta vad någon sagt.",
      "icon": "💬",
      "pointsRequired": 0,
      "bonusPoints": 30,
      "exercises": [
        {
          "id": "hog-g4-1",
          "type": "multiple-choice",
          "question": "Direct: 'I am tired,' she said. What is the reported speech?",
          "options": [
            "She said that she is tired.",
            "She said that she was tired.",
            "She said that I am tired.",
            "She said she is being tired."
          ],
          "correctIndex": 1,
          "explanation": "In reported speech, we 'backshift' tenses: am/is → was. She said that she was tired."
        },
        {
          "id": "hog-g4-2",
          "type": "build-sentence",
          "instruction": "Report this question: 'Where do you live?' she asked me.",
          "words": [
            "She",
            "asked",
            "me",
            "where",
            "I",
            "lived",
            "."
          ],
          "correctOrder": [
            0,
            1,
            2,
            3,
            4,
            5,
            6
          ],
          "explanation": "Reported questions: no question word order (no inversion), backshift tense. 'do you live' → 'I lived'."
        }
      ]
    },
